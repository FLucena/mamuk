{
  "name": "mamuk",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:env": "NODE_ENV=development next dev",
    "dev:win": "set NODE_ENV=development && next dev",
    "build": "next build",
    "build:win": "set NODE_ENV=production && next build",
    "start": "NODE_ENV=production next start",
    "start:win": "set NODE_ENV=production && next start",
    "lint": "next lint",
    "type-check": "tsc --noEmit",
    "security-audit": "ts-node scripts/security-audit.ts",
    "security-audit:cron": "ts-node scripts/cron-security-audit.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:ci": "npm run test && npm run test:e2e",
    "msw:init": "msw init public"
  },
  "dependencies": {
    "@auth/mongodb-adapter": "^3.7.4",
    "@headlessui/react": "^2.2.0",
    "@radix-ui/react-dropdown-menu": "^2.1.6",
    "@types/node-cron": "^3.0.11",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "ioredis": "^5.6.0",
    "isomorphic-dompurify": "^2.22.0",
    "lucide-react": "^0.477.0",
    "mongodb": "^6.3.0",
    "mongoose": "^8.1.0",
    "next": "14.2.24",
    "next-auth": "^4.24.5",
    "next-themes": "^0.4.4",
    "node-cron": "^3.0.3",
    "react": "^18",
    "react-dom": "^18",
    "react-hot-toast": "^2.5.2",
    "react-icons": "^5.5.0",
    "react-select": "^5.8.0",
    "sonner": "^2.0.1",
    "swiper": "^11.1.12",
    "tailwind-merge": "^3.0.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.51.0",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@types/node": "20.17.19",
    "@types/react": "18.3.18",
    "@types/react-dom": "^18.0.0",
    "autoprefixer": "^10",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "mongodb-memory-server": "^10.1.4",
    "msw": "^0.47.4",
    "node-mocks-http": "^1.16.2",
    "postcss": "^8",
    "supertest": "^7.0.0",
    "tailwindcss": "^3",
    "typescript": "5.7.3"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}
