    "puppeteer": "^24.4.0",
    "rimraf": "^5.0.5",
    "sharp": "^0.33.5",
    "stream-browserify": "^3.0.0",
    "stream-http": "^3.2.0",
    "supertest": "^7.0.0",
    "tailwindcss": "^3",
    "ts-jest": "^29.2.6",
    "ts-node": "^10.9.2",
    "typescript": "5.7.3",
    "undici": "^6.21.1",
    "url": "^0.11.4",
    "util": "^0.12.5",
    "webpack-bundle-analyzer": "^4.10.2"
  }
