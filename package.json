{
  "name": "mamuk",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:win": "set NODE_ENV=development && next dev",
    "dev:http2": "node server.js",
    "build": "next build",
    "build:win": "set NODE_ENV=production && next build && node scripts/generate-source-maps.js",
    "build:custom": "node build.js",
    "build:simple": "node scripts/simple-build.js",
    "build:minimal": "node scripts/use-minimal-config.js",
    "build:nolint": "next build --no-lint && node scripts/generate-source-maps.js",
    "build:sourcemaps": "node scripts/generate-source-maps.js",
    "start": "NODE_ENV=production next start",
    "start:win": "set NODE_ENV=production && next start",
    "start:http2": "NODE_ENV=production node server.js",
    "start:http2:win": "set NODE_ENV=production && node server.js",
    "lint": "next lint",
    "type-check": "tsc --noEmit",
    "security-audit": "ts-node scripts/security-audit.ts",
    "security-audit:cron": "ts-node scripts/cron-security-audit.ts",
    "db:create-indexes": "node scripts/create-indexes.js",
    "db:create-indexes:win": "set NODE_ENV=development && node scripts/create-indexes.js",
    "update-loading": "node scripts/update-loading-components.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:ci": "npm run test && npm run test:e2e",
    "test:navigation": "node disable-throttling.js",
    "migrate:roles": "node scripts/run-role-migration.js",
    "fix:roles": "node scripts/fix-user-roles.js",
    "convert-images": "ts-node scripts/convert-to-webp.ts",
    "optimize:images": "node scripts/optimize-images.js",
    "analyze": "ANALYZE=true next build",
    "analyze:win": "set ANALYZE=true && next build",
    "performance:audit": "lighthouse http://localhost:3000 --view",
    "performance:audit:admin": "lighthouse http://localhost:3000/admin --view",
    "clean:cache": "rimraf .next && rimraf node_modules/.cache"
  },
  "dependencies": {
    "@auth/mongodb-adapter": "^3.8.0",
