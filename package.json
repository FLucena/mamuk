    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^29.5.14",
    "@types/node": "20.17.19",
    "@types/react": "18.3.18",
    "@types/react-dom": "^18.0.0",
    "@types/sharp": "^0.32.0",
    "bcryptjs": "^3.0.2",
    "browserify-zlib": "^0.2.0",
    "buffer": "^6.0.3",
    "chalk": "^5.4.1",
    "critters": "^0.0.23",
    "crypto-browserify": "^3.12.1",
