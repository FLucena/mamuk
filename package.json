    "headlessui": "^0.0.0",
    "html2canvas": "^1.4.1",
    "ioredis": "^5.6.0",
    "isomorphic-dompurify": "^2.22.0",
    "jose": "^5.2.3",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.358.0",
    "mongodb": "^6.14.2",
    "mongoose": "^8.2.1",
    "next": "^14.1.3",
    "next-auth": "^4.24.7",
    "next-themes": "^0.2.1",
    "node-cron": "^3.0.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hook-form": "^7.51.0",
